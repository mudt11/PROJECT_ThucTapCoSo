# ============================================================
#  .gitignore — ĐẶT Ở ROOT DỰ ÁN
# ============================================================

# --- Env files: KHÔNG BAO GIỜ commit file thật ---
.env
.env.local
.env.*.local
Server/.env
Server/.env.local
AI_Services/.env

# Chỉ commit file mẫu
!.env.example
!Server/.env.example
!AI_Services/.env.example

# --- Dependencies ---
node_modules/
**/node_modules/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# --- Build outputs ---
dist/
build/
.next/
**/.next/

# --- Database dumps ---
*.sql.bak
# Chú ý: db/init.sql NÊN commit 
# Chỉ thêm vào đây nếu chứa data nhạy cảm
# db/init.sql

# --- Logs ---
*.log
npm-debug.log*
pip-debug.log*

# --- Cache ---
.cache/
.turbo/
.pytest_cache/
.ipynb_checkpoints/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Python notebook artifacts ---
*.ipynb_checkpoints/